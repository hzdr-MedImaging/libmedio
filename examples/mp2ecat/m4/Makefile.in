@SET_MAKE@

top_builddir = ..

ACLOCAL			= aclocal
AUTOCONF		= autoconf
AUTOHEADER	= autoheader
RM					= @RM_PATH@ -f
RMDIR				= $(RM) -r
COPY				= @CP_PATH@ -af 
CHMOD				= @CHMOD_PATH@

all:  $(top_builddir)/configure

# Check on makefile.in in current dir
Makefile:  Makefile.in  $(top_builddir)/config.status
	cd $(top_builddir) && ./config.status

$(top_builddir)/configure:  configure.in aclocal.m4
	(cd $(top_builddir) && $(AUTOHEADER) m4/configure.in)
	$(AUTOCONF) configure.in > $(top_builddir)/configure
	$(CHMOD) u+x $(top_builddir)/configure

aclocal.m4: acinclude.m4
	$(ACLOCAL)

install:	

clean:
	$(RM) configure config.status config.log

distclean: clean
	$(RM) Makefile
	$(RMDIR) autom4te.cache
