TEMPLATE		= app
CONFIG			*= qt thread warn_on @ANSI_COLOR@ @QTLINK_LEVEL@
QT					+= core
QMAKE_QMAKE = @QMAKE_PATH@
TARGET			= mp2ecat
VERSION			= @PACKAGE_VERSION@
DESTDIR			= ../
DEFINES			*=

# directory specification
OBJECTS_DIR = .obj
MOC_DIR			= .moc
UI_DIR			= .ui

DEPENDPATH	+= . includes
INCLUDEPATH	+= . includes

# own QMAKE Flags definitions
QMAKE_CXXFLAGS_RELEASE = @CXXFLAGS@
QMAKE_CXXFLAGS_DEBUG	 = @CXXFLAGS@

# find out the host os/cpu
HOST_OS=@HOST_OS@
HOST_CPU=@HOST_CPU@
HOST_MACHINE=@HOST_MACHINE@

# set the config to either release or debug
COMPILE_LEVEL = @COMPILE_LEVEL@
contains(COMPILE_LEVEL, debug) {
	CONFIG -= release
	CONFIG *= debug
	QMAKE_CXXFLAGS_DEBUG += -ggdb -O0
	DEFINES *= DEBUG
}
else {
	CONFIG -= debug
	CONFIG *= release
	QMAKE_CXXFLAGS_RELEASE += -O3 -funroll-loops
	QMAKE_LINK *= -s # this is for stripping the executable while linking
	DEFINES -= DEBUG
}

### QT LIB ################################################################
# if "staticqt" is specificed in the CONFIG variable (by configure)
# we link with the static QT library instead
staticqt {
	QMAKE_LIBS_QT =
	QMAKE_LIBS_QT_THREAD =
	!macx:LIBS *= $(QTDIR)/lib/libqt-mt.a
	macx:LIBS *= $(QTDIR)/lib/libqt-mt.a -lz -framework Carbon
}

### LIBRTDEBUG ############################################################
# if "staticrtdebug" is specified in the CONFIG variable (by configure)
# we link wih the static variant of librtdebug instead
INCLUDEPATH *= @RTDEBUG_INCDIR@
contains(DEFINES, DEBUG) {
	staticmedio {
		LIBS *= @RTDEBUG_LIBDIR@/librtdebug.a
	}
	else {
		LIBS *= -L@RTDEBUG_LIBDIR@ @LIB_RTDEBUG@
	}
}

### LIBMEDIO ##############################################################
# if "staticmedio" is specified in the CONFIG variable (by configure)
# we link wih the static variant of libmedio instead
INCLUDEPATH *= @MEDIO_INCDIR@
staticmedio {
	LIBS *= @MEDIO_LIBDIR@/libmedio.a
}
else {
	LIBS *= @MEDIO_LIBDIR@/@LIB_MEDIO@
}

# set defines so that we can identify the processor type later on
contains(HOST_MACHINE, x86_64) {
  DEFINES *= __X86_64__
}
contains(HOST_MACHINE, i[63]86) {
  DEFINES *= __i386__
}
contains(HOST_MACHINE, sun4u) {
  DEFINES *= __SPARC__
}
contains(HOST_MACHINE, Power.+) {
  DEFINES *= __POWERPC__
}

!mac {
  contains(HOST_MACHINE, x86_64) {
    QMAKE_CFLAGS_RELEASE *= -mtune=native
    QMAKE_CXXFLAGS_RELEASE *= -mtune=native
  }
  contains(HOST_MACHINE, i[63]86) {
    QMAKE_CFLAGS_RELEASE *= -mtune=native
    QMAKE_CXXFLAGS_RELEASE *= -mtune=native
  }
  contains(HOST_MACHINE, sun4u) {
    QMAKE_CFLAGS_RELEASE *= -mcpu=ultrasparc3
    QMAKE_CXXFLAGS_RELEASE *= -mcpu=ultrasparc3
  }
  contains(HOST_MACHINE, Power.+) {
    QMAKE_CFLAGS_RELEASE *= -mcpu=powerpc
    QMAKE_CXXFLAGS_RELEASE *= -mcpu=powerpc
  }
}

# override the compile output
QMAKE_CXX  = @echo \'  CC   $<\'; $$QMAKE_CXX
QMAKE_LINK = @echo \'  LD   $@\'; $$QMAKE_LINK
QMAKE_MOC  = @echo \'  MOC  $@\'; $$QMAKE_MOC

# use ANSI colors if it was specified on configure time
ansi_color {
  DEFINES *= ANSI_COLOR
}
else {
  DEFINES -= ANSI_COLOR
}

# Input
HEADERS +=	CDataArray.h \
						CApplication.h

SOURCES +=	CApplication.cpp \
						mp2ecat.cpp
