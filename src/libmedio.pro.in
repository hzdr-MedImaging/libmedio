# main variables
TEMPLATE  = lib
CONFIG	 *= qt thread warn_on @ANSI_COLOR@ @QTLINK_LEVEL@
QT			  = core
TARGET    = medio
VERSION   = 2.0.2
DESTDIR   = ../lib/

# directory specification
OBJECTS_DIR = .obj
MOC_DIR     = .moc
UI_DIR      = .ui

# define headers and source files for compilation
# PUB_HEADER: public headers going into /usr/local/include/medio
# HEADERS...: all headers including private ones
# SOURCES...: all source files required for the compilation

PUB_HEADER =	CMedIOHeader.h \
		CMedIOData.h \
		CMedIODataFactory.h \
		ecat/CECATDirectory.h \
		ecat/CECATDirectoryItem.h \
		ecat/CECATFile.h \
		ecat/CECATMainHeader.h \
		ecat/CECATSubHeader.h \
		ecat/ecat6/CECAT6MainHeader.h \
		ecat/ecat7/CECAT7MainHeader.h \
		ecat/ecat7/CECAT7SubHeaderAttenCorr.h \
		ecat/ecat7/CECAT7SubHeaderImage.h \
		ecat/ecat7/CECAT7SubHeaderNorm.h \
		ecat/ecat7/CECAT7SubHeaderNorm3D.h \
		ecat/ecat7/CECAT7SubHeaderPolarMap.h \
		ecat/ecat7/CECAT7SubHeaderScan.h \
		ecat/ecat7/CECAT7SubHeaderScan3D.h \
		helpers/CKeyType.h \
    helpers/CKeyValue.h \
    helpers/CKeyParser.h \
		micropet/CConcordeMainHeader.h \
		micropet/CConcordeMainHeaderSinogram.h \
		micropet/CConcordeMainHeaderImage.h \
		micropet/CConcordeFrameHeader.h \
		micropet/CConcordeFile.h \
		micropet/CConcordeSinogram.h \
		micropet/CConcordeImage.h \
		micropet/CIntVector.h \
		micropet/CDate.h

HEADERS  = $$PUB_HEADER

SOURCES  = \
	   CMedIOHeader.cpp \
	   CMedIOData.cpp \
	   CMedIODataFactory.cpp \
	   ecat/CECATDirectory.cpp \
	   ecat/CECATDirectoryItem.cpp \
	   ecat/CECATFile.cpp \
	   ecat/ecat6/CECAT6MainHeader.cpp \
	   ecat/ecat7/CECAT7MainHeader.cpp \
 	   ecat/ecat7/CECAT7SubHeaderAttenCorr.cpp \
	   ecat/ecat7/CECAT7SubHeaderImage.cpp \
	   ecat/ecat7/CECAT7SubHeaderNorm.cpp \
	   ecat/ecat7/CECAT7SubHeaderNorm3D.cpp \
	   ecat/ecat7/CECAT7SubHeaderPolarMap.cpp \
	   ecat/ecat7/CECAT7SubHeaderScan.cpp \
	   ecat/ecat7/CECAT7SubHeaderScan3D.cpp \
	   helpers/CKeyValue.cpp \
     helpers/CKeyParser.cpp \
	   micropet/CConcordeMainHeader.cpp \
	   micropet/CConcordeMainHeaderSinogram.cpp \
	   micropet/CConcordeMainHeaderImage.cpp \
	   micropet/CConcordeFrameHeader.cpp \
	   micropet/CConcordeFile.cpp \
	   micropet/CConcordeSinogram.cpp \
	   micropet/CConcordeImage.cpp \
	   micropet/CIntVector.cpp \
		 micropet/CDate.cpp

DEPENDPATH   = . ecat ecat/ecat6 ecat/ecat7 micropet
INCLUDEPATH  = . include ecat ecat/ecat6 ecat/ecat7 micropet helpers

# UNIX based target platforms installation defines
unix {
  # on unix we use configure to define everything like install path
	PREFIX=@prefix@
  LIB_DIR=@prefix@/lib
  INCLUDE_DIR=@prefix@/include
  DATA_DIR=@prefix@/share
	
  # -p option should be -P, so that "make install" as root creates files owned by root
  # and links are preserved.
  QMAKE_COPY_FILE = $(COPY) -P
	
  # install header 
  include.path  = $$INCLUDE_DIR/medio
  include.files = $$PUB_HEADER

  # install documentation html
  documentation.path = $$DATA_DIR/medio/doc
  documentation.files = ../doc/*.html ../doc/*.css

  # install library
  target.path = $$LIB_DIR

  # "make install" configuration options
  INSTALLS += target include documentation
}

# set the config to either release or debug
COMPILE_LEVEL = @COMPILE_LEVEL@
contains(COMPILE_LEVEL, debug) {
	CONFIG -= release
	CONFIG += debug
	QMAKE_CXXFLAGS_DEBUG *= -g -O0
	DEFINES *= DEBUG
}
else {
	CONFIG -= debug
	CONFIG += release
	QMAKE_CXXFLAGS_RELEASE *= -O3 -fomit-frame-pointer -funroll-loops
	QMAKE_LINK *= -s 
	DEFINES -= DEBUG
}

### LIBRTDEBUG ############################################################
# if "staticrtdebug" is specified in the CONFIG variable (by configure)
# we link wih the static variant of librtdebug instead
INCLUDEPATH *= @RTDEBUG_INCDIR@
contains(DEFINES, DEBUG) {
	staticmedio {
		LIBS *= @RTDEBUG_LIBDIR@/librtdebug.a
	}
	else {
		LIBS *= -L@RTDEBUG_LIBDIR@ @LIB_RTDEBUG@
	}
}

# own QMAKE Flags definitions
QMAKE_CXXFLAGS_RELEASE	= @CXXFLAGS@
QMAKE_CXXFLAGS_DEBUG	= @CXXFLAGS@

# for static compilation we define the following so that we
# can define "staticconfig" in CONFIG if we want static linking.
staticconfig {
	QMAKE_LIBS_QT =
	QMAKE_LIBS_QT_THREAD =
	!macx:LIBS += $(QTDIR)/lib/libqt-mt.a
	macx:LIBS += $(QTDIR)/lib/libqt-mt.a -lz -framework Carbon
}

# find out the GCC version
# and define some gcc v3+ options only.
GCC_VERSION = @GCC_VERSION@
contains(GCC_VERSION, 3) {
	QMAKE_CXXFLAGS *= -fmessage-length=0
}

# find out the system
HOST_OS=@HOST_OS@
HOST_CPU=@HOST_CPU@
contains(HOST_CPU, sparc) {
	QMAKE_CXXFLAGS *= -mcpu=v9 -mtune=ultrasparc3
}
else {
	contains(HOST_CPU, [pP]ower[pP]c) {
      QMAKE_CXXFLAGS *= -Acpu=powerpc -mcpu=G4
  }
  else {
		contains(HOST_CPU, [oO]pteron.+) {			
			QMAKE_CXXFLAGS *= -Acpu=amd64 -march=opteron
		}
	}
}



# use ANSI colors if it was specified on configure time
ansi_color {
	QMAKE_CXX		= @printf '\033[32mCompiling $<\033[0m\n';$$QMAKE_CXX
	QMAKE_LINK	= @printf '\033[32mLinking \033[1m$@\033[0m\n';$$QMAKE_LINK
	DEFINES += ANSI_COLOR
}
