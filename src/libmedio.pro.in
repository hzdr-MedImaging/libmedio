# main variables
TEMPLATE    = lib
CONFIG     *= qt thread no_mocdepend warn_on create_prl @ANSI_COLOR@ @QTLINK_LEVEL@
QT          = core
QMAKE_QMAKE = @QMAKE_PATH@
TARGET      = medio
VERSION      = @PACKAGE_VERSION@
DESTDIR      = ../lib/
DEFINES     *= __MEDIO_PRIVATE__

# directory specification
unix {
  OBJECTS_DIR = .obj
  MOC_DIR     = .moc
  UI_DIR      = .ui
}
win32 {
  OBJECTS_DIR = _obj
  MOC_DIR     = _moc
  UI_DIR      = _ui
}

# define headers and source files for compilation
# PUB_HEADER: public headers going into /usr/local/include/medio
# HEADERS...: all headers including private ones
# SOURCES...: all source files required for the compilation

PUB_HEADER =  CMedIO.h \
              CMedIOHeader.h \
              CMedIOData.h \
              CMedIODataFactory.h \
              ecat/CECATDirectory.h \
              ecat/CECATDirectoryItem.h \
              ecat/CECATFile.h \
              ecat/CECATMainHeader.h \
              ecat/CECATSubHeader.h \
              ecat/ecat6/CECAT6MainHeader.h \
              ecat/ecat7/CECAT7MainHeader.h \
              ecat/ecat7/CECAT7SubHeaderAttenCorr.h \
              ecat/ecat7/CECAT7SubHeaderImage.h \
              ecat/ecat7/CECAT7SubHeaderNorm.h \
              ecat/ecat7/CECAT7SubHeaderNorm3D.h \
              ecat/ecat7/CECAT7SubHeaderPolarMap.h \
              ecat/ecat7/CECAT7SubHeaderScan.h \
              ecat/ecat7/CECAT7SubHeaderScan3D.h \
              micropet/CConcordeMainHeader.h \
              micropet/CConcordeMainHeaderSinogram.h \
              micropet/CConcordeMainHeaderImage.h \
              micropet/CConcordeFrameHeader.h \
              micropet/CConcordeFile.h \
              micropet/CConcordeSinogram.h \
              micropet/CConcordeImage.h \
              philips/CPhilipsFile.h \
              philips/CPhilipsMainHeader.h \
              philips/CPhilipsDirectory.h \
              helpers/MedIOUnits.h \

HEADERS  = $$PUB_HEADER \
           helpers/CKeyType.h \
           helpers/CKeyValue.h \
           helpers/CKeyParser.h \           
           helpers/CIntVector.h \
           helpers/CDate.h

SOURCES  = CMedIO.cpp \
           CMedIOHeader.cpp \
           CMedIOData.cpp \
           CMedIODataFactory.cpp \
           helpers/CKeyValue.cpp \
           helpers/CKeyParser.cpp \
           helpers/CIntVector.cpp \
           helpers/CDate.cpp \
           helpers/MedIOUnits.cpp \
           ecat/CECATDirectory.cpp \
           ecat/CECATDirectoryItem.cpp \
           ecat/CECATFile.cpp \
           ecat/CECATMainHeader.cpp \
           ecat/CECATSubHeader.cpp \     
           ecat/ecat6/CECAT6MainHeader.cpp \
           ecat/ecat7/CECAT7MainHeader.cpp \
           ecat/ecat7/CECAT7SubHeaderAttenCorr.cpp \
           ecat/ecat7/CECAT7SubHeaderImage.cpp \
           ecat/ecat7/CECAT7SubHeaderNorm.cpp \
           ecat/ecat7/CECAT7SubHeaderNorm3D.cpp \
           ecat/ecat7/CECAT7SubHeaderPolarMap.cpp \
           ecat/ecat7/CECAT7SubHeaderScan.cpp \
           ecat/ecat7/CECAT7SubHeaderScan3D.cpp \
           micropet/CConcordeMainHeader.cpp \
           micropet/CConcordeMainHeaderSinogram.cpp \
           micropet/CConcordeMainHeaderImage.cpp \
           micropet/CConcordeFrameHeader.cpp \
           micropet/CConcordeFile.cpp \
           micropet/CConcordeSinogram.cpp \
           micropet/CConcordeImage.cpp \
           philips/CPhilipsFile.cpp \
           philips/CPhilipsMainHeader.cpp \
           philips/CPhilipsDirectory.cpp

DEPENDPATH   = . ecat ecat/ecat6 ecat/ecat7 micropet philips
INCLUDEPATH  = . include ecat ecat/ecat6 ecat/ecat7 micropet philips helpers

# find out the host os/cpu
HOST_OS=@HOST_OS@
HOST_CPU=@HOST_CPU@
HOST_MACHINE=@HOST_MACHINE@

# set the config to either release or debug
COMPILE_LEVEL = @COMPILE_LEVEL@
contains(COMPILE_LEVEL, debug) {
  CONFIG -= release
  CONFIG *= debug
  DEBUG = -DDEBUG
}
else {
  CONFIG -= debug
  CONFIG *= release
  DEBUG =
  QMAKE_LINK *= -s
}

QMAKE_EXTRA_VARIABLES = DEBUG
MAKE_CXXFLAGS *= $(EXPORT_DEBUG)
QMAKE_CFLAGS *= $(EXPORT_DEBUG)
QMAKE_CXXFLAGS *= $(EXPORT_DEBUG)

# find out if the R interface should be included
# and set the source files of the interface
R_INTERFACE = @R_INTERFACE@
contains(R_INTERFACE, enabled) {

  PUB_HEADER += rcpp/CRECATFile.h \
                rcpp/RInterface.h

  HEADER += rcpp/CRECATFile.h \
            rcpp/RInterface.h

  SOURCES += rcpp/CRECATFile.cpp \
             rcpp/RInterface.cpp

  DEFINES *= WITH_R_INTERFACE
}

# UNIX based target platforms installation defines
# on unix we use configure to define everything like install path
PREFIX=@prefix@
LIB_DIR=@prefix@/lib
INCLUDE_DIR=@prefix@/include
DATA_DIR=@prefix@/share

# -p option should be -P, so that "make install" as root creates files owned by root
# and links are preserved.
QMAKE_COPY_FILE = $(COPY) -P

# C++ include stubs
stubs.path = $$INCLUDE_DIR/medio
stubs.files = ./include/stubs/*

# install header 
include.path  = $$INCLUDE_DIR/medio/2
include.files = $$PUB_HEADER

# install documentation html
documentation.path = $$DATA_DIR/medio/doc
documentation.files = ../doc/*.html ../doc/*.css

# install library
target.path = $$LIB_DIR

# "make install" configuration options
INSTALLS += target stubs include

# mac specific options to build universal
# binaries for specific platforms
mac {
  CONFIG += x86 ppc x86_64
}

# as an result of a buggy qmake win implementation
# QMAKE_TARGET is not defined on windows, so we
# add the install target ourself
win32:staticlib {
  target.files *= $${DESTDIR}libmedio.a $${DESTDIR}libmedio.prl
}

### LIBRTDEBUG ############################################################
# if "staticrtdebug" is specified in the CONFIG variable (by configure)
# we link wih the static variant of librtdebug instead
INCLUDEPATH *= @RTDEBUG_INCDIR@
contains(DEFINES, DEBUG) {
  staticmedio {
    LIBS *= @RTDEBUG_LIBDIR@/@LIB_RTDEBUG@
  }
  else {
    LIBS *= -L@RTDEBUG_LIBDIR@ @LIB_RTDEBUG@
  }
}

### Rcpp ##################################################################
INCLUDEPATH *= @RCPP_INCDIR@
contains(DEFINES, WITH_R_INTERFACE) {
  staticrcpp {
    LIBS *= @RCPP_LIBDIR@/@LIB_RCPP@
  }
  else {
    LIBS *= -L@RCPP_LIBDIR@ @LIB_RCPP@ -Wl,-rpath,@RCPP_LIBDIR@
  }
}

### R ####################################################################
contains(DEFINES, WITH_R_INTERFACE) {
  INCLUDEPATH *= @R_INCDIR@
}

# for static compilation we define the following so that we
# can define "staticconfig" in CONFIG if we want static linking.
staticconfig {
  QMAKE_LIBS_QT =
  QMAKE_LIBS_QT_THREAD =
}

# set the general compiler optimizations
QMAKE_CFLAGS_RELEASE = -O3 -fomit-frame-pointer -funroll-loops
QMAKE_CXXFLAGS_RELEASE = -O3 -fomit-frame-pointer -funroll-loops

# tune the optimization a bit for each architecture
!mac {
  contains(HOST_MACHINE, x86_64) {
    QMAKE_CFLAGS_RELEASE *= -mtune=native
    QMAKE_CXXFLAGS_RELEASE *= -mtune=native
  }
  contains(HOST_MACHINE, i[63]86) {
    QMAKE_CFLAGS_RELEASE *= -mtune=native
    QMAKE_CXXFLAGS_RELEASE *= -mtune=native
  }
  contains(HOST_MACHINE, sun4u) {
    QMAKE_CFLAGS_RELEASE *= -mcpu=ultrasparc3
    QMAKE_CXXFLAGS_RELEASE *= -mcpu=ultrasparc3
  }
  contains(HOST_MACHINE, Power.+) {
    QMAKE_CFLAGS_RELEASE *= -mcpu=powerpc
    QMAKE_CXXFLAGS_RELEASE *= -mcpu=powerpc
  }
}

# override the compile output
QMAKE_CXX  = @echo \'  CC   $<\'; $$QMAKE_CXX
QMAKE_LINK = @echo \'  LD   $@\'; $$QMAKE_LINK
QMAKE_MOC  = @echo \'  MOC  $@\'; $$QMAKE_MOC

# use ANSI colors if it was specified on configure time
ansi_color {
  DEFINES *= ANSI_COLOR
}
else {
  DEFINES -= ANSI_COLOR
}
